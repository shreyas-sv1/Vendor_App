// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ USER & AUTHENTICATION ============

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  email         String   @unique
  phone         String   @unique
  password      String   // Bcrypt hashed

  // Profile fields
  firstName     String?
  lastName      String?
  dob           DateTime?
  category      String?  // "Grocery", "Food", "Vegetables", "Clothes"
  profileImage  String?  // Cloudinary URL

  // Status
  isOnline      Boolean  @default(false)
  isVerified    Boolean  @default(false)

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastLoginAt   DateTime?

  // Relations
  location       Location?
  orders         Order[]
  cartUploads    CartUpload[]
  supportTickets SupportTicket[]
  notifications  Notification[]
  sessions       Session[]
  earnings       Earning[]

  @@index([email])
  @@index([phone])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
}

model OTPCode {
  id        String   @id @default(uuid())
  phone     String
  code      String   // 6-digit OTP
  type      String   // "REGISTRATION", "PASSWORD_RESET"
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone, type])
}

// ============ LOCATION ============

model Location {
  id        String   @id @default(uuid())
  userId    String   @unique
  latitude  Float
  longitude Float
  address   String?
  city      String?
  state     String?
  zipCode   String?

  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([latitude, longitude])
}

// ============ ORDERS ============

model Order {
  id         String   @id @default(cuid()) // "#ORD1001" format
  vendorId   String

  // Order details
  items      String   // "2x Samosa, 1x Chai"
  price      Float
  status     OrderStatus @default(PENDING)

  // Customer info
  customerName    String
  customerPhone   String?
  deliveryAddress String
  deliveryLat     Float?
  deliveryLng     Float?

  // Timing
  estimatedTime  String?  // "10m"
  placedAt       DateTime @default(now())
  acceptedAt     DateTime?
  deliveredAt    DateTime?

  // Relations
  vendor         User     @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, status])
  @@index([placedAt])
}

enum OrderStatus {
  PENDING
  ACCEPTED
  DELIVERED
  CANCELLED
}

// ============ CART UPLOADS ============

model CartUpload {
  id        String   @id @default(uuid())
  vendorId  String
  imageUrl  String   // Cloudinary URL
  publicId  String   // Cloudinary public_id for deletion

  // Metadata
  fileSize  Int      // bytes
  width     Int?
  height    Int?

  createdAt DateTime @default(now())

  vendor    User     @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, createdAt])
}

// ============ EARNINGS & ANALYTICS ============

model Earning {
  id        String   @id @default(uuid())
  vendorId  String
  date      DateTime @default(now())
  amount    Float
  orderId   String?  // Link to order (optional)

  createdAt DateTime @default(now())

  vendor    User     @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, date])
}

// ============ NOTIFICATIONS ============

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      NotificationType
  isRead    Boolean  @default(false)

  // Optional metadata (JSON)
  data      Json?

  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

enum NotificationType {
  NEW_ORDER
  ORDER_UPDATE
  SYSTEM_ALERT
  PROMOTIONAL
}

// ============ SUPPORT ============

model SupportTicket {
  id        String   @id @default(uuid())
  vendorId  String
  subject   String?
  message   String
  status    TicketStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor    User     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  replies   SupportReply[]

  @@index([vendorId, status])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model SupportReply {
  id        String   @id @default(uuid())
  ticketId  String
  message   String
  isStaff   Boolean  @default(false)

  createdAt DateTime @default(now())

  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}
